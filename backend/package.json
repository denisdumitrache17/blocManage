{
  "name": "blocmanage-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "prisma:generate": "prisma generate --schema ./schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ./schema.prisma",
    "prisma:studio": "prisma studio --schema ./schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
